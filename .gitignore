# ==============================================================================
# 通用忽略规则
# ==============================================================================

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*~

# 备份文件
*.bak
*.backup

# 日志文件
*.log
logs/
log/

# 数据库文件
*.db
*.sqlite
*.sqlite3

# OS 生成文件
.DS_Store
Thumbs.db
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# IDE 和编辑器文件
.idea/
.vscode/
.vs/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 版本控制文件
.git/
.svn/
.hg/

# ==============================================================================
# Go 语言忽略规则
# ==============================================================================

# 可执行文件
*.exe
*.exe~
*.dll
*.so
*.dylib

# 测试文件
*.test

# 覆盖率文件
*.out

# 依赖目录
vendor/

# Go 工作区文件
go.work
go.work.sum

# 模块缓存
pkg/

# ==============================================================================
# Python 语言忽略规则
# ==============================================================================

# 编译文件
*.pyc

# 缓存目录
__pycache__/
.pytest_cache/
.tox/
.venv/
env/
env.local/
env.*.local/

# 测试报告
htmlcov/
.coverage
.coverage.*
.cache

# 构建文件
build/
dist/
*.egg-info/
.installed.cfg

# ==============================================================================
